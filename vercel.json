{
  "version": 2,
  "name": "swordforge",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/serverless.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/serverless.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
